{
	"name": "@magenta/harness",
	"version": "0.0.1",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"prebuild": "npm run check:structure && npm run generate:hcp-sources && npm run check:hcp-sources && npm run build:process-tools",
		"build": "shx rm -rf dist && node ../scripts/tsc.mjs -p tsconfig.build.json && node scripts/copy-assets.mjs",
		"build:process-tools": "node scripts/build-process-tools.mjs",
		"generate:hcp-sources": "node scripts/generate-hcp-sources.mjs",
		"check:hcp-sources": "node scripts/generate-hcp-sources.mjs --check",
		"check:structure": "node scripts/check-structure.mjs",
		"check:assumptions": "node scripts/audit-assumptions.mjs --check",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"inspect": "node scripts/inspect.mjs",
		"test": "vitest --run"
	},
	"dependencies": {
		"@earendil-works/pi-agent-core": "0.80.2",
		"@earendil-works/pi-ai": "0.80.2",
		"smol-toml": "1.7.0"
	},
	"optionalDependencies": {
		"node-pty": "1.0.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"@typescript-eslint/eslint-plugin": "8.63.0",
		"@typescript-eslint/parser": "8.63.0",
		"@typescript/typescript6": "6.0.2",
		"eslint": "10.6.0",
		"eslint-plugin-unicorn": "71.1.0",
		"shx": "0.4.0",
		"typescript": "7.0.2",
		"vitest": "4.1.9"
	},
	"description": "Magenta3 Harness Modules assembled through HcpClient, HcpServer, and HcpMagnet.",
	"directories": {
		"doc": "docs",
		"test": "test"
	},
	"keywords": [],
	"author": "",
	"license": "ISC"
}
