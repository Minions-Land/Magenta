node_modules/
dist/
*.log
# Stray compiled artifacts emitted outside dist/ (source dirs must stay .ts-only)
# Root-level process-tools build output (Mach-O/ELF binary emitted into cwd by the
# build). Anchored to the repo root with a leading slash so the tracked source dir
# HarnessComponentProtocol/_magenta/ is NOT affected.
/_magenta/
harness/**/*.js
harness/**/*.js.map
harness/**/*.d.ts
harness/**/*.d.ts.map
HarnessComponentProtocol/**/*.js
HarnessComponentProtocol/**/*.js.map
HarnessComponentProtocol/**/*.d.ts
HarnessComponentProtocol/**/*.d.ts.map
.DS_Store
*.tsbuildinfo
__pycache__/
*.py[cod]
pi/*/dist/
pi/*/dist-chrome/
pi/*/dist-firefox/
packages/*/dist/
packages/*/dist-chrome/
packages/*/dist-firefox/
*.cpuprofile

# Local Pi runtime data (sessions, settings, and CREDENTIALS — never commit)
.pi-source/
.pi/

# Test artifacts
test-results/
playwright-report/
test-cli/
test-conversation/
tests/fixtures/
test-external-auth.mjs

# Backups
*.backup

# Environment
.env

# Editor files
.vscode/
.zed/
.idea/
.claude/
*.swp
*.swo
*~

# Scratch / working notes
.tmp/

# Package specific
# Pixi materialized environments (multi-GB conda envs — never commit)
.pixi/
packages/**/.pixi/
# Omics run outputs (generated analysis artifacts, not fixtures)
runs/
# Skill catalog build stamps (regenerated timestamps, not source)
**/.catalog_stamp
# Downloaded datasets / demo figures (regenerated, never fixtures)
data/
figures/
.npm/
coverage/
.nyc_output/
.pi_config/
tui-debug.log
compaction-results/
.opencode/
