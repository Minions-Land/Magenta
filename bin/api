#!/usr/bin/env bash
set -e

# 凭证自动抓取由 CLI 内部的 external-auth-loader.ts 完成，
# 按 provider 依次解析 key 与 base_url（优先级从高到低）：
#   1. 已有环境变量（ANTHROPIC_AUTH_TOKEN/ANTHROPIC_API_KEY、OPENAI_API_KEY 等）
#   2. Claude Code（~/.claude/settings.json -> env.ANTHROPIC_*）
#   3. Codex（~/.codex/auth.json + config.toml，取当前 model_provider 段的 base_url）
# 该逻辑无条件执行，因此自动抓取默认开启，无需在此处做 shell 层抓取。
# 环境里已 export 的凭证会被子进程继承。

# 相对本脚本定位构建好的 CLI，保证从任意 cwd 启动都能工作。
# 把 bin 目录放进 PATH，这样子进程（例如 sub-agent）也能启动同一套 Magenta 命令。
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
exec node "$SCRIPT_DIR/../pi/coding-agent/dist/cli.js" "$@"
