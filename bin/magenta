#!/usr/bin/env bash
set -e

# Credential autodetection is handled inside the CLI by external-auth-loader.ts,
# which resolves keys and base URLs in this priority order (per provider):
#   1. Existing environment variables (ANTHROPIC_AUTH_TOKEN/ANTHROPIC_API_KEY, OPENAI_API_KEY, ...)
#   2. Claude Code  (~/.claude/settings.json -> env.ANTHROPIC_* )
#   3. Codex        (~/.codex/auth.json + config.toml, active model_provider's base_url)
# It is invoked unconditionally, so autodetection is always on and needs no shell setup here.
# Any credentials already exported in the environment are inherited by the child process.

# Resolve the built CLI relative to this script so the launcher works from any cwd.
# Keep this directory on PATH so child Magenta processes (for example sub-agents)
# can spawn the same branded command even when the user invoked this file by path.
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
export PATH="$SCRIPT_DIR:$PATH"
exec node "$SCRIPT_DIR/../pi/coding-agent/dist/cli.js" "$@"
