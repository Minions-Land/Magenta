{
	"extends": "./tsconfig.base.json",
	"compilerOptions": {
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@earendil-works/pi-ai": ["./pi/ai/src/index.ts"],
			"@earendil-works/pi-ai/oauth": ["./pi/ai/src/oauth.ts"],
			"@earendil-works/pi-ai/*": ["./pi/ai/src/*.ts", "./pi/ai/src/providers/*.ts"],
			"@earendil-works/pi-ai/dist/*": ["./pi/ai/src/*"],
			"@earendil-works/pi-agent-core": ["./pi/agent/src/index.ts"],
			"@earendil-works/pi-agent-core/*": ["./pi/agent/src/*"],
			"@earendil-works/pi-coding-agent": ["./pi/coding-agent/src/index.ts"],
			"@earendil-works/pi-coding-agent/*": ["./pi/coding-agent/src/*"],
			"@magenta/harness": ["./HarnessComponentProtocol/index.ts"],
			"@magenta/harness/*": ["./HarnessComponentProtocol/*"],
			"@magenta/memory": ["./HarnessComponentProtocol/memory/pi/index.ts"],
			"@magenta/memory/*": ["./HarnessComponentProtocol/memory/pi/*"],
			"typebox": ["./node_modules/typebox"],
			"@earendil-works/pi-tui": ["./pi/tui/src/index.ts"],
			"@earendil-works/pi-tui/*": ["./pi/tui/src/*"]
		}
	},
	"include": ["pi/*/src/**/*", "pi/*/test/**/*", "pi/coding-agent/examples/**/*", "HarnessComponentProtocol/**/*"],
	"exclude": ["**/dist/**", "pi/coding-agent/examples/extensions/gondolin/**", "pi/coding-agent/src/extensions-disabled/**"]
}
