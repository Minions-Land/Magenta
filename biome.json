{
	"$schema": "https://biomejs.dev/schemas/2.3.5/schema.json",
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"style": {
				"noNonNullAssertion": "off",
				"useConst": "error",
				"useNodejsImportProtocol": "off"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noControlCharactersInRegex": "off",
				"noEmptyInterface": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"formatWithErrors": false,
		"indentStyle": "tab",
		"indentWidth": 3,
		"lineWidth": 120
	},
	"files": {
		"includes": [
			"pi/*/src/**/*.ts",
			"pi/*/test/**/*.ts",
			"pi/coding-agent/examples/**/*.ts",
			"HarnessComponentProtocol/**/*.ts",
			"!**/.magenta/**/*",
			"!**/node_modules/**/*",
			"!**/dist/**/*",
			"!**/test-sessions.ts",
			"!**/models.generated.ts",
			"!**/image-models.generated.ts",
			"!**/*.models.ts",
			"!!**/node_modules"
		]
	}
}
